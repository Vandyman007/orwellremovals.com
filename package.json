{
  "name": "orwellremovals-com",
  "version": "1.0.0",
  "private": true,
  "description": "Orwell Removals & Storage — static SEO site for orwellremovals.com (Ipswich & Suffolk removals and storage)",
  "scripts": {
    "build:css": "tailwindcss -i ./tools/css/site.input.css -o ./css/site.min.css --minify",
    "watch:css": "tailwindcss -i ./tools/css/site.input.css -o ./css/site.min.css --watch",
    "build": "npm run build:css && python3 tools/build.py"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.1"
  }
}
